{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"endOfLine": "lf",
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"sortImports": {
		"newlinesBetween": false
	},
	"sortTailwindcss": true,
	"ignorePatterns": [
		"apps/downloads-poller/*",
		"apps/feature-flags-service/*",
		"apps/blog/src/data/countries-110m.json",
		"apps/tanstack/src/lib/embed/assets/countries-110m.json",
		"apps/tanstack/src/routeTree.gen.ts"
	]
}
