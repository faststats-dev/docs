---
// @ts-expect-error - Virtual Module for MobileMenuToggle component
import MobileMenuToggle from "virtual:starlight/components/MobileMenuToggle";

const { hasSidebar } = Astro.locals.starlightRoute;
const siteKey = process.env.PUBLIC_FASTSTATS_SITE_KEY;
---

{
    process.env.NODE_ENV === "production" && siteKey && (
        <script is:inline define:vars={{ siteKey }}>
            import { WebAnalytics } from "@faststats/web";

            new WebAnalytics({
                siteKey,
                webVitals: { enabled: true },
                sessionReplays: { enabled: true },
                errorTracking: { enabled: true },
            });
        </script>
    )
}

<div class="page sl-flex">
    <header class="header"><slot name="header" /></header>
    {
        hasSidebar && (
            <nav
                class="sidebar print:hidden"
                aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}
            >
                <MobileMenuToggle />
                <div id="starlight__sidebar" class="sidebar-pane">
                    <div class="sidebar-content sl-flex">
                        <slot name="sidebar" />
                    </div>
                </div>
            </nav>
        )
    }
    <div class="main-frame"><slot /></div>
</div>

<style>
    @layer starlight.core {
        .page {
            flex-direction: column;
            min-height: 100vh;
        }

        .header {
            z-index: var(--sl-z-index-navbar);
            position: fixed;
            inset-inline-start: 0;
            inset-block-start: 0;
            width: 100%;
            height: var(--sl-nav-height);
            border-bottom: 0;
            box-shadow: none;
            padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
            padding-inline-end: var(--sl-nav-pad-x);
            background-color: var(--sl-color-bg-nav);
        }

        .sidebar-pane {
            visibility: var(--sl-sidebar-visibility, hidden);
            position: fixed;
            z-index: var(--sl-z-index-menu);
            inset-block: var(--sl-nav-height) 0;
            inset-inline-start: 0;
            width: 100%;
            background-color: var(--sl-color-black);
            overflow-y: auto;
        }

        :global([aria-expanded="true"]) ~ .sidebar-pane {
            --sl-sidebar-visibility: visible;
        }

        .sidebar-content {
            height: 100%;
            min-height: max-content;
            padding: 1rem var(--sl-sidebar-pad-x) 0;
            flex-direction: column;
            gap: 1rem;
        }

        @media (min-width: 48rem) {
            .sidebar-content::after {
                content: "";
                padding-bottom: 1px;
            }

            :global(:root[data-has-sidebar]) {
                --sl-layout-offset: max(0px, calc((100vw - var(--sl-layout-width)) / 2));
                --sl-content-inline-start: calc(
                    var(--sl-layout-offset) + var(--sl-sidebar-width)
                ) !important;
                --sl-content-margin-inline: 0;
                --sl-content-pad-x: 1.5rem;
                --sl-content-pt: 2rem;
            }

            .sidebar-pane {
                --sl-sidebar-visibility: visible;
                display: flex;
                flex-direction: column;
                inset-block: 0;
                inset-inline-start: 0;
                z-index: calc(var(--sl-z-index-navbar) + 1);
                width: calc(var(--sl-layout-offset) + var(--sl-sidebar-width));
                background-color: var(--sl-color-bg-sidebar);
                border-inline-end: 1px solid var(--sl-color-hairline-shade);
                overflow: hidden;
            }

            .sidebar-content {
                flex: 1;
                min-height: 0;
                width: 100%;
            }

            .main-frame {
                margin-inline-end: var(--sl-layout-offset);
                margin-inline-start: 0;
                max-width: none;
                padding-inline-start: var(--sl-content-inline-start) !important;
            }
        }

        .main-frame {
            padding-top: calc(
                var(--sl-nav-height) + var(--sl-mobile-toc-height)
            );
            padding-inline-start: var(--sl-content-inline-start);
        }

        @media (min-width: 80rem) {
            :global(:root[data-has-sidebar]) {
                --sl-content-pad-x: 2rem;
                --sl-content-pt: 3.5rem;
            }
        }

        @media (max-width: 49.99rem) {
            :global([data-has-sidebar]) .header {
                padding-inline-end: calc(
                    var(--sl-nav-gap) + var(--sl-nav-pad-x) +
                        var(--sl-menu-button-size)
                );
            }
        }
    }
</style>
