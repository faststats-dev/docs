---
import SidebarPersister from "@astrojs/starlight/components/SidebarPersister.astro";
import Search from "virtual:starlight/components/Search";
import SocialIcons from "virtual:starlight/components/SocialIcons";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import { getCollection } from "astro:content";
import SidebarBrand from "./sidebar-brand.astro";
import SidebarSublist from "./sidebar-sublist.astro";
import TopicsSelector from "./topics/TopicsSelector.astro";

const { sidebar } = Astro.locals.starlightRoute;

const docs = await getCollection("docs");
const iconMap = new Map<string, string>();
for (const doc of docs) {
    if (typeof doc.data.icon === "string") {
        iconMap.set(doc.id.replace(/\/index$/, ""), doc.data.icon);
    }
}
---

<div class="sidebar-aside flex min-h-0 flex-1 flex-col">
    <div
        class="sidebar-pane-section sidebar-banner flex shrink-0 flex-col gap-3 p-4 pb-2"
    >
        <div class="flex justify-between">
            <SidebarBrand />
        </div>
        <div class="sidebar-search-host">
            <Search />
        </div>
    </div>
    <div class="sidebar-mobile-topics hidden max-[49.99rem]:block">
        <TopicsSelector />
    </div>
    <div
        class="sidebar-pane-section sidebar-scroll flex flex-col gap-0.5 overscroll-contain px-4 pb-4 pt-0"
    >
        <SidebarPersister>
            <SidebarSublist entries={sidebar} iconMap={iconMap} />
        </SidebarPersister>
    </div>
    <div
        class="sidebar-pane-section sidebar-footer mt-auto hidden shrink-0 items-center gap-3 border-t border-[var(--sl-color-hairline-shade)] px-3 py-2.5 md:flex"
    >
        <div class="sidebar-social">
            <SocialIcons />
        </div>
        <ThemeSelect />
    </div>
</div>

<style>
    .sidebar-mobile-topics {
        border-bottom: 1px solid var(--sl-color-hairline-shade);
        padding: 0.75rem 1rem 0;
    }

    .sidebar-footer :global(starlight-theme-select) {
        margin-inline-start: auto;
    }

    .sidebar-social {
        align-items: center;
        display: flex;
        gap: 0.75rem;
    }

    .sidebar-social :global(a) {
        color: var(--sl-color-gray-3);
        margin: 0;
        padding: 0;
    }

    .sidebar-social :global(a:hover) {
        color: var(--sl-color-gray-1);
    }

    .sidebar-social :global(svg) {
        height: 1.25rem;
        width: 1.25rem;
    }

    :global(#starlight__sidebar) {
        font-family: var(--sl-font-mono);
        font-size: 0.875rem;
        line-height: 1.25;
        scrollbar-width: none;
    }

    :global(#starlight__sidebar::-webkit-scrollbar) {
        display: none;
    }

    :global(#starlight__sidebar .sidebar-content) {
        gap: 0;
        height: 100%;
        min-height: 0;
        padding: 0;
    }

    .sidebar-aside {
        width: 100%;
    }

    @media (min-width: 48rem) {
        .sidebar-aside {
            align-items: flex-end;
        }

        .sidebar-pane-section {
            box-sizing: border-box;
            min-width: var(--sl-sidebar-width);
            width: var(--sl-sidebar-width);
        }
    }

    :global(#starlight__sidebar .sidebar-scroll) {
        mask-image: linear-gradient(
            to bottom,
            white,
            white calc(100% - 12px),
            transparent
        );
        scrollbar-width: none;
    }

    @media (min-width: 48rem) {
        :global(#starlight__sidebar .sidebar-scroll) {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
        }
    }

    :global(#starlight__sidebar .sidebar-scroll::-webkit-scrollbar) {
        display: none;
    }

    .sidebar-search-host {
        min-width: 0;
        width: 100%;
    }

    :global(#starlight__sidebar .sidebar-search-host site-search) {
        display: block !important;
        width: 100% !important;
    }

    :global(
        #starlight__sidebar
            .sidebar-search-host
            site-search
            button[data-open-modal]
    ) {
        align-items: center;
        background: color-mix(
            in oklch,
            var(--sl-color-gray-5) 50%,
            transparent
        );
        border: 1px solid var(--sl-color-hairline);
        box-sizing: border-box;
        color: var(--sl-color-gray-2);
        cursor: pointer;
        display: flex !important;
        font-size: 0.875rem;
        gap: 0.5rem;
        height: auto !important;
        max-width: none !important;
        min-height: 0 !important;
        padding: 0.375rem 0.375rem 0.375rem 0.5rem;
        text-align: start;
        transition:
            background-color 0.15s,
            color 0.15s;
        width: 100% !important;

        svg {
            flex-shrink: 0;
            height: 1rem;
            width: 1rem;
        }

        > span {
            display: inline !important;
            line-height: 1.25rem;
        }

        &:hover {
            background: var(--sl-color-gray-5);
            border-color: var(--sl-color-hairline);
            color: var(--sl-color-white);
        }
    }

    :global(
        :root[data-theme="light"]
            #starlight__sidebar
            .sidebar-search-host
            site-search
            button[data-open-modal]:hover
    ) {
        color: var(--sl-color-gray-1);
    }

    :global(.sidebar-footer select) {
        background-color: var(--sl-color-gray-6) !important;
        border-color: var(--sl-color-hairline) !important;
        color: var(--sl-color-gray-2) !important;
    }
</style>
