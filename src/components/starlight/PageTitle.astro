---
const { title, description } = Astro.locals.starlightRoute.entry.data;
---

<h1 id="_top">{title}</h1>
{description && <p class="page-description">{description}</p>}

<style is:global>
	main > .content-panel:first-child .sl-container {
		align-items: stretch;
		display: flex;
		flex-direction: column;
	}

	main > .content-panel:first-child .sl-container > * {
		margin-top: 0;
	}

	main > .content-panel:first-child .sl-copy-button-row {
		display: contents;
	}

	main > .content-panel:first-child .sl-copy-button-row > h1,
	main > .content-panel:first-child .sl-container h1 {
		color: var(--sl-color-white);
		font-family: var(--sl-font-mono);
		font-size: 1.875rem;
		font-weight: 500;
		letter-spacing: -0.025em;
		line-height: 1.2;
		margin: 0;
		order: 1;
	}

	@media (min-width: 48rem) {
		main > .content-panel:first-child .sl-copy-button-row > h1,
		main > .content-panel:first-child .sl-container h1 {
			font-size: 2.25rem;
		}
	}

	main > .content-panel:first-child .page-description {
		color: var(--sl-color-gray-2);
		font-size: 1.0625rem;
		line-height: 1.625;
		margin: 0.75rem 0 0;
		order: 2;
	}

	main > .content-panel:first-child .sl-copy-button-controls {
		border-bottom: 1px solid var(--sl-color-hairline);
		justify-content: flex-start;
		margin: 0.5rem 0 0;
		order: 3;
		padding: 0.5rem 0 1.5rem;
		position: relative;
		width: 100%;
	}

	main > .content-panel:first-child .sl-copy-button-live-region {
		height: 0;
		inset-inline-start: 0;
		overflow: visible;
		pointer-events: none;
		position: absolute;
		top: 0.5rem;
		width: 0;
		z-index: 2;
	}

	main > .content-panel:first-child .sl-copy-button-feedback {
		bottom: calc(100% + 0.35rem);
		inset-inline-end: auto !important;
		inset-inline-start: 0 !important;
		margin: 0 !important;
		position: absolute;
		top: auto !important;
		transform: translate3d(0, 0.25rem, 0);
		white-space: nowrap;
	}

	main > .content-panel:first-child .sl-copy-button-feedback::after {
		border-inline-end-color: transparent !important;
		border-inline-start-color: transparent !important;
		border-top-color: var(--tooltip-bg) !important;
		inset-inline-end: auto !important;
		inset-inline-start: 0.75rem !important;
		top: 100% !important;
	}

	main > .content-panel:first-child .sl-copy-button-feedback.show {
		transform: translate3d(0, 0, 0);
	}

	main > .content-panel:first-child .sl-copy-button-controls--with-label .sl-copy-button {
		background: color-mix(in oklch, var(--sl-color-gray-5) 50%, transparent) !important;
		border: 1px solid var(--sl-color-hairline) !important;
		color: var(--sl-color-gray-2) !important;
		font-family: var(--sl-font-mono);
		font-size: 0.8125rem;
		height: auto !important;
		min-height: 1.75rem;
		opacity: 1 !important;
		padding: 0.25rem 0.5rem !important;
		width: auto !important;
	}

	main > .content-panel:first-child .sl-copy-button-controls--with-label .sl-copy-button:hover {
		background: color-mix(in oklch, var(--sl-color-gray-5) 80%, transparent) !important;
		color: var(--sl-color-white) !important;
	}
</style>
