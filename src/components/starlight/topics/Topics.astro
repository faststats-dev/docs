---
import starlightConfig from "virtual:starlight/user-config";
import { Badge, Icon } from "@astrojs/starlight/components";
import { AstroError } from "astro/errors";
import type { ComponentProps } from "astro/types";

const { topics } = Astro.locals.starlightSidebarTopics;

const defaultLang =
  starlightConfig.defaultLocale?.lang ||
  starlightConfig.defaultLocale?.locale ||
  "en";

function getTranslation(
  translations: Record<string, string>,
  link: string,
  description: string,
) {
  const defaultTranslation = translations[defaultLang];

  if (!defaultTranslation) {
    throw new AstroError(
      `The ${description} for "${link}" must have a key for the default language "${defaultLang}".`,
      "Update the Starlight config to include a topic label for the default language.",
    );
  }

  let translation = defaultTranslation;

  if (Astro.currentLocale) {
    translation = translations[Astro.currentLocale] ?? defaultTranslation;
  }

  return translation;
}
---

<div
  class="flex flex-row items-end gap-6 overflow-x-auto h-10 max-lg:hidden"
  data-header-tabs
>
  {
    topics.map((topic) => {
      const label =
        typeof topic.label === "string"
          ? topic.label
          : getTranslation(topic.label, topic.link, "topic label");

      return (
        <a
          href={topic.link}
          class:list={["header-tab", { "header-tab-current": topic.isCurrent }]}
        >
          <span class="header-tab-label">
            {topic.icon && (
              <Icon
                name={topic.icon as ComponentProps<typeof Icon>["name"]}
                class="header-tab-icon"
              />
            )}
            {label}
            {topic.badge && (
              <Badge
                class="header-tab-badge"
                text={
                  typeof topic.badge.text === "string"
                    ? topic.badge.text
                    : getTranslation(
                        topic.badge.text,
                        topic.link,
                        "topic badge text",
                      )
                }
                variant={topic.badge.variant}
              />
            )}
          </span>
        </a>
      );
    })
  }
</div>

<style>
  .header-tabs::-webkit-scrollbar {
    display: none;
  }

  .header-tab {
    align-items: center;
    border-bottom: 2px solid transparent;
    color: var(--sl-color-gray-3);
    display: inline-flex;
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    gap: 0.5rem;
    padding-bottom: 0.375rem;
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .header-tab:hover,
  .header-tab:focus-visible {
    color: var(--sl-color-white);
  }

  .header-tab-current {
    border-bottom-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .header-tab-label {
    align-items: center;
    display: inline-flex;
    gap: 0.5rem;
  }

  .header-tab-icon {
    flex-shrink: 0;
    height: 1rem;
    width: 1rem;
  }

  .header-tab-badge {
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-inline-start: 0.375rem;
    padding: 0.125rem 0.375rem;
    text-transform: uppercase;
  }
</style>
