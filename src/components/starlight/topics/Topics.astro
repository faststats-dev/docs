---
import starlightConfig from "virtual:starlight/user-config";
import { Badge, Icon } from "@astrojs/starlight/components";
import { AstroError } from "astro/errors";
import type { ComponentProps } from "astro/types";

const { topics } = Astro.locals.starlightSidebarTopics;

const defaultLang =
  starlightConfig.defaultLocale?.lang ||
  starlightConfig.defaultLocale?.locale ||
  "en";

function getText(
  value: string | Record<string, string>,
  link: string,
  description: string,
) {
  if (typeof value === "string") return value;

  const translations = value;
  const defaultTranslation = translations[defaultLang];

  if (!defaultTranslation) {
    throw new AstroError(
      `The ${description} for "${link}" must have a key for the default language "${defaultLang}".`,
      "Update the Starlight config to include a topic label for the default language.",
    );
  }

  return Astro.currentLocale
    ? (translations[Astro.currentLocale] ?? defaultTranslation)
    : defaultTranslation;
}
---

<nav
  class="flex h-10 scrollbar-none items-end gap-6 overflow-x-auto [&::-webkit-scrollbar]:hidden"
  aria-label="Topics"
>
  {
    topics.map((topic) => {
      const label = getText(topic.label, topic.link, "topic label");

      return (
        <a
          href={topic.link}
          class:list={[
            "inline-flex items-center gap-2 border-b-2 pb-1.5 font-mono text-sm font-medium whitespace-nowrap no-underline",
            topic.isCurrent
              ? "border-(--sl-color-accent) text-(--sl-color-accent)"
              : "border-transparent text-(--sl-color-gray-3) hover:text-(--sl-color-white) focus-visible:text-(--sl-color-white)",
          ]}
        >
          {topic.icon && (
            <Icon
              name={topic.icon as ComponentProps<typeof Icon>["name"]}
              class="size-4 shrink-0"
            />
          )}
          {label}
          {topic.badge && (
            <Badge
              class="ms-1.5 border border-(--sl-color-hairline) bg-(--sl-color-gray-6) px-1.5 py-0.5 text-[0.625rem] font-medium tracking-wider text-(--sl-color-gray-3) uppercase"
              text={getText(topic.badge.text, topic.link, "topic badge text")}
              variant={topic.badge.variant}
            />
          )}
        </a>
      );
    })
  }
</nav>
