---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
/*
NOTE: This page is a redirect to the /platform/ page. It is used as the index page for the site, but we want to redirect users to the platform page instead of showing them the index page.
*/
---

<StarlightPage
    frontmatter={{
        title: "FastStats Docs",
        description:
            "Error tracking, session replays, web vitals, funnels, and retention in one platform — stop stitching five tools together. Free during closed beta.",
        template: "splash",
    }}
>
    <meta http-equiv="refresh" content="0;url=/platform/" />
</StarlightPage>
