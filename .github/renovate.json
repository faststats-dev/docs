{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		"security:minimumReleaseAgeNpm",
		":disableDependencyDashboard"
	],
	"minimumReleaseAge": "1 day",
	"packageRules": [
		{
			"groupName": "fumadocs",
			"matchPackageNames": [
				"fumadocs-core",
				"fumadocs-mdx",
				"fumadocs-openapi",
				"fumadocs-ui"
			]
		},
		{
			"groupName": "takumi",
			"matchPackageNames": ["@takumi-rs/core", "@takumi-rs/image-response"]
		}
	]
}
